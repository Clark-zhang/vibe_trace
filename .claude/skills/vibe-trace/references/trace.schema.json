{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibetrace.dev/schemas/trace.schema.json",
  "title": "Vibe Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "source",
    "source_session_id",
    "title",
    "workspace",
    "started_at",
    "messages",
    "tool_calls",
    "tool_results",
    "file_changes",
    "checkpoints",
    "git",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "codex",
        "claude_code",
        "cursor",
        "cline",
        "kiro",
        "copilot",
        "manual_json",
        "fixture",
        "unknown"
      ]
    },
    "source_session_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "messages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolCall"
      }
    },
    "tool_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolResult"
      }
    },
    "file_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileChange"
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkpoint"
      }
    },
    "git": {
      "$ref": "#/$defs/gitState"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "default": []
    },
    "privacy_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/privacyFinding"
      },
      "default": []
    },
    "redactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/redaction"
      },
      "default": []
    },
    "publish": {
      "$ref": "#/$defs/publishMetadata"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "repo_url": {
          "type": ["string", "null"]
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message_id",
        "role",
        "content",
        "created_at",
        "tool_call_ids",
        "privacy_findings",
        "metadata"
      ],
      "properties": {
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "system", "tool"]
        },
        "content": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "model": {
          "type": ["string", "null"]
        },
        "parent_id": {
          "type": ["string", "null"]
        },
        "tool_call_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "privacy_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/privacyFinding"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "toolCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_call_id",
        "name",
        "created_at",
        "arguments",
        "metadata"
      ],
      "properties": {
        "tool_call_id": {
          "type": "string",
          "minLength": 1
        },
        "message_id": {
          "type": ["string", "null"]
        },
        "name": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "succeeded", "failed", "unknown"]
        },
        "arguments": {
          "$ref": "#/$defs/metadata"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "toolResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_result_id",
        "tool_call_id",
        "created_at",
        "status",
        "content",
        "metadata"
      ],
      "properties": {
        "tool_result_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_call_id": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["succeeded", "failed", "unknown"]
        },
        "content": {
          "type": "string"
        },
        "privacy_findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/privacyFinding"
          },
          "default": []
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "fileChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_change_id", "path", "change_type", "metadata"],
      "properties": {
        "file_change_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        },
        "change_type": {
          "type": "string",
          "enum": ["added", "modified", "deleted", "renamed", "unknown"]
        },
        "old_path": {
          "type": ["string", "null"]
        },
        "language": {
          "type": ["string", "null"]
        },
        "additions": {
          "type": "integer",
          "minimum": 0
        },
        "deletions": {
          "type": "integer",
          "minimum": 0
        },
        "diff": {
          "type": ["string", "null"]
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "gitState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_root",
        "branch",
        "head_sha",
        "is_dirty",
        "changed_files",
        "untracked_files",
        "metadata"
      ],
      "properties": {
        "repo_root": {
          "type": ["string", "null"]
        },
        "remote_url": {
          "type": ["string", "null"]
        },
        "branch": {
          "type": ["string", "null"]
        },
        "head_sha": {
          "type": ["string", "null"]
        },
        "is_dirty": {
          "type": "boolean"
        },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "untracked_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diff": {
          "type": ["string", "null"]
        },
        "commit_message": {
          "type": ["string", "null"]
        },
        "pr_url": {
          "type": ["string", "null"]
        },
        "issue_url": {
          "type": ["string", "null"]
        },
        "test_command": {
          "type": ["string", "null"]
        },
        "test_result": {
          "type": ["string", "null"],
          "enum": ["passed", "failed", "unknown", null]
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "trace_id",
        "label",
        "kind",
        "reason",
        "created_at",
        "git",
        "test_status",
        "metadata"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["auto", "manual"]
        },
        "reason": {
          "type": "string",
          "enum": [
            "before_agent",
            "after_edit",
            "tests_passed",
            "pre_commit",
            "commit",
            "user_marked"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "git": {
          "$ref": "#/$defs/checkpointGitState"
        },
        "diff_ref": {
          "type": ["string", "null"]
        },
        "test_status": {
          "type": "string",
          "enum": ["passed", "failed", "unknown"]
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "checkpointGitState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_root",
        "branch",
        "head_sha",
        "hidden_ref",
        "is_dirty"
      ],
      "properties": {
        "repo_root": {
          "type": ["string", "null"]
        },
        "branch": {
          "type": ["string", "null"]
        },
        "head_sha": {
          "type": ["string", "null"]
        },
        "hidden_ref": {
          "type": ["string", "null"]
        },
        "is_dirty": {
          "type": "boolean"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "kind", "name", "path", "metadata"],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["file", "image", "video", "log", "report", "other"]
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"]
        },
        "mime_type": {
          "type": ["string", "null"]
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "privacyFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "kind",
        "severity",
        "location",
        "preview",
        "metadata"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "api_key",
            "access_token",
            "ssh_key",
            "private_key",
            "env",
            "cookie",
            "session",
            "database_url",
            "webhook_url",
            "internal_ip",
            "internal_domain",
            "email",
            "phone",
            "local_path",
            "private_repo",
            "sensitive_name",
            "unknown"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "location": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        },
        "start": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "end": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "redaction_id",
        "finding_id",
        "replacement",
        "applied",
        "metadata"
      ],
      "properties": {
        "redaction_id": {
          "type": "string",
          "minLength": 1
        },
        "finding_id": {
          "type": "string"
        },
        "replacement": {
          "type": "string"
        },
        "applied": {
          "type": "boolean"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "publishMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "tags", "metadata"],
      "properties": {
        "visibility": {
          "type": "string",
          "enum": ["local", "private", "unlisted", "public"]
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outcome": {
          "type": "string"
        },
        "published_url": {
          "type": ["string", "null"]
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    }
  }
}
